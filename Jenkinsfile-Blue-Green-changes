pipeline {

    agent { label 'deploy-agent-deploy' }

    options {
        skipDefaultCheckout(true)
    }

    environment {
        ARTIFACTORY_URL = "http://192.168.56.1:8082/artifactory/eshop-generic-local"
        ZIP_NAME = "eshop-latest.zip"

        // Banner environment variable
        DEPLOY_ENV = "blue"
    }

    stages {

        stage('Download Artifact') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'artifactory-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {

                    bat '''
                    curl -L -u %USER%:%PASS% -o %ZIP_NAME% %ARTIFACTORY_URL%/%ZIP_NAME%
                    '''

                }
            }
        }

        stage('Extract Artifact') {
            steps {

                bat '''
                if exist extracted rmdir /s /q extracted
                powershell Expand-Archive -Path %ZIP_NAME% -DestinationPath extracted -Force
                '''

            }
        }

        stage('Backup Config Files') {
            steps {

                bat '''
                powershell Copy-Item C:\\inetpub\\eshop\\web.config C:\\inetpub\\web.config.bak -ErrorAction SilentlyContinue
                powershell Copy-Item C:\\inetpub\\eshop\\appsettings.json C:\\inetpub\\appsettings.json.bak -ErrorAction SilentlyContinue
                '''

            }
        }

        stage('Stop IIS') {
            steps {
                bat 'powershell Stop-WebAppPool -Name eshop'
            }
        }

        stage('Deploy Files') {
            steps {

                bat '''
                robocopy extracted C:\\inetpub\\eshop /E /R:1 /W:1
                IF %ERRORLEVEL% LEQ 3 EXIT 0
                '''

            }
        }

        stage('Restore Config Files') {
            steps {

                bat '''
                powershell Copy-Item C:\\inetpub\\web.config.bak C:\\inetpub\\eshop\\web.config -Force
                powershell Copy-Item C:\\inetpub\\appsettings.json.bak C:\\inetpub\\eshop\\appsettings.json -Force
                '''

            }
        }

        stage('Set Deployment Environment') {
            steps {

                bat '''
                echo Setting DEPLOY_ENV=%DEPLOY_ENV%
                '''

            }
        }

        stage('Start IIS') {
            steps {
                bat 'powershell Start-WebAppPool -Name eshop'
            }
        }

    }

}
