pipeline {

    agent { label 'deploy-agent-deploy' }

    environment {
        ARTIFACTORY_URL = "http://192.168.56.1:8082/artifactory/eshop-generic-local"
    }

    stages {

        stage('Find Latest Artifact') {

            steps {

                script {

                    bat '''
                    curl -s %ARTIFACTORY_URL%/api/storage?list > artifacts.json
                    '''

                    bat '''
                    powershell -Command "(Get-Content artifacts.json | ConvertFrom-Json).files | Where-Object {$_.uri -like '*.zip'} | Select-Object -Last 1 -ExpandProperty uri | Out-File artifact.txt"
                    '''

                    script {
                        env.ARTIFACT_NAME = readFile('artifact.txt').trim().replace("/", "")
                        echo "Latest Artifact Found: ${ARTIFACT_NAME}"
                    }

                }

            }

        }

        stage('Download Artifact') {

            steps {

                withCredentials([usernamePassword(credentialsId: 'artifactory-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {

                    bat '''
                    curl.exe -L -u %USER%:%PASS% -o %ARTIFACT_NAME% %ARTIFACTORY_URL%/%ARTIFACT_NAME%
                    '''

                }

            }

        }

        stage('Extract Artifact') {

            steps {

                bat '''
                powershell -Command "Expand-Archive -Path %ARTIFACT_NAME% -DestinationPath extracted -Force"
                '''

            }

        }

        stage('Stop IIS AppPool') {

            steps {

                bat '''
                powershell -Command "Import-Module WebAdministration; Stop-WebAppPool -Name 'eshop'"
                '''

            }

        }

        stage('Deploy Application') {

            steps {

                bat '''
                robocopy extracted C:\\inetpub\\eshop /E /R:1 /W:1 /XF web.config appsettings.json
                IF %ERRORLEVEL% LEQ 3 EXIT 0
                '''

            }

        }

        stage('Start IIS AppPool') {

            steps {

                bat '''
                powershell -Command "Import-Module WebAdministration; Start-WebAppPool -Name 'eshop'"
                '''

            }

        }

    }

}
