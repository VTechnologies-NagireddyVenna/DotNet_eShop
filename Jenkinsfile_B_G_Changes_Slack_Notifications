/*
CD PIPELINE – BLUE GREEN DEPLOYMENT WITH SLACK NOTIFICATIONS

1. Downloads latest application artifact from Artifactory.
2. Detects currently active environment (Blue or Green) using IIS proxy config.
3. Extracts the artifact and deploys it to the inactive environment.
4. Waits for application startup and performs health check on target port.
5. If health check succeeds, switches IIS proxy traffic to the new environment.
6. Sends Slack notification on SUCCESS or FAILURE of deployment.
7. Ensures zero-downtime deployment using Blue-Green strategy.
*/

pipeline {

    agent { label 'deploy-agent-deploy' }

    options {
        skipDefaultCheckout(true)
    }

    environment {

        ARTIFACTORY_URL = "http://192.168.56.1:8082/artifactory/eshop-generic-local"
        PROXY_CONFIG = "C:\\inetpub\\proxy\\web.config"
        ZIP_NAME = "latest.zip"
        SLACK_CHANNEL = "#jenkins-deployments"

    }

    stages {

        stage('Download Artifact') {

            steps {

                withCredentials([usernamePassword(
                        credentialsId: 'artifactory-creds',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                )]) {

                    bat '''
                    echo Downloading latest artifact from Artifactory...
                    curl -L -u %USER%:%PASS% -o %ZIP_NAME% %ARTIFACTORY_URL%/eshop-latest.zip
                    '''

                }

            }

        }

        stage('Detect Active Environment') {

            steps {

                script {

                    def proxyContent = readFile(env.PROXY_CONFIG)

                    if(proxyContent.contains("8081")) {

                        env.ACTIVE_ENV  = "blue"
                        env.TARGET_ENV  = "green"
                        env.TARGET_PORT = "8082"
                        env.TARGET_PATH = "C:\\inetpub\\eshop-green"

                    } else {

                        env.ACTIVE_ENV  = "green"
                        env.TARGET_ENV  = "blue"
                        env.TARGET_PORT = "8081"
                        env.TARGET_PATH = "C:\\inetpub\\eshop-blue"

                    }

                    echo "Active Environment : ${env.ACTIVE_ENV}"
                    echo "Deploying To       : ${env.TARGET_ENV}"
                    echo "Deploy Path        : ${env.TARGET_PATH}"
                    echo "Target Port        : ${env.TARGET_PORT}"

                }

            }

        }

        stage('Extract Artifact') {

            steps {

                bat '''
                echo Extracting deployment package...
                if exist extracted rmdir /s /q extracted
                powershell Expand-Archive %ZIP_NAME% extracted -Force
                '''

            }

        }

        stage('Deploy to Target Environment') {

            steps {

                bat """
                echo Deploying application to ${env.TARGET_ENV}

                robocopy extracted ${env.TARGET_PATH} /E /PURGE /R:1 /W:1 ^
                /XF web.config appsettings.json env.txt

                IF %ERRORLEVEL% LEQ 3 EXIT 0
                """

            }

        }

        stage('Wait For Application Startup') {

            steps {

                echo "Waiting 20 seconds for application startup..."
                sleep(time:20, unit:"SECONDS")

            }

        }

        stage('Health Check') {

            steps {

                script {

                    def retries = 5
                    def success = false

                    for(int i=0; i<retries; i++) {

                        echo "Health check attempt ${i+1}"

                        def status = bat(
                                script: "@curl -s -o nul -w \"%%{http_code}\" http://127.0.0.1:${env.TARGET_PORT}",
                                returnStdout: true
                        ).trim()

                        echo "HTTP Status: ${status}"

                        if(status.contains("200")) {

                            success = true
                            break

                        }

                        sleep(time:5, unit:"SECONDS")

                    }

                    if(!success) {

                        error "Health check failed after multiple retries"

                    }

                }

            }

        }

        stage('Switch Traffic') {

            steps {

                script {

                    if(env.TARGET_PORT == "8082") {

                        powershell """
                        (Get-Content ${env.PROXY_CONFIG}) -replace '8081','8082' |
                        Set-Content ${env.PROXY_CONFIG}
                        """

                    } else {

                        powershell """
                        (Get-Content ${env.PROXY_CONFIG}) -replace '8082','8081' |
                        Set-Content ${env.PROXY_CONFIG}
                        """

                    }

                    echo "Traffic switched to ${env.TARGET_ENV}"

                }

            }

        }

    }

    post {

        success {

            echo "Deployment completed successfully"
            echo "Active environment is now ${env.TARGET_ENV}"

            slackSend (
                channel: "${SLACK_CHANNEL}",
                color: 'good',
                message: """
SUCCESS: Deployment completed

Application : eShop
Environment : ${env.TARGET_ENV}
Build       : ${env.BUILD_NUMBER}
Job         : ${env.JOB_NAME}

Details:
${env.BUILD_URL}
"""
            )

        }

        failure {

            echo "Deployment failed - traffic not switched"

            slackSend (
                channel: "${SLACK_CHANNEL}",
                color: 'danger',
                message: """
FAILED: Deployment failed

Application : eShop
Job         : ${env.JOB_NAME}
Build       : ${env.BUILD_NUMBER}

Check Logs:
${env.BUILD_URL}
"""
            )

        }

    }

}
