/*
CD PIPELINE – BLUE GREEN DEPLOYMENT WITH SLACK NOTIFICATIONS + DUAL MANUAL APPROVAL

1. Requires manual approval before starting production deployment.
2. Downloads latest artifact from Artifactory.
3. Detects active IIS environment (Blue/Green).
4. Deploys artifact to the inactive environment.
5. Waits for application startup and performs health checks.
6. Requests second manual approval before switching production traffic.
7. Switches IIS proxy traffic to the new environment.
8. Sends Slack notification for SUCCESS or FAILURE.
*/

pipeline {

    agent { label 'deploy-agent-deploy' }

    options {
        skipDefaultCheckout(true)
    }

    environment {
        ARTIFACTORY_URL = "http://192.168.56.1:8082/artifactory/eshop-generic-local"
        PROXY_CONFIG = "C:\\inetpub\\proxy\\web.config"
        ZIP_NAME = "latest.zip"
    }

    stages {

        stage('Production Deployment Approval') {
            steps {
                timeout(time: 60, unit: 'MINUTES') {
                    input message: """
PRODUCTION DEPLOYMENT APPROVAL REQUIRED

Application : eShop
Action      : Start Production Deployment

Approve deployment to continue?
"""
                }
            }
        }

        stage('Download Artifact') {
            steps {

                withCredentials([usernamePassword(
                        credentialsId: 'artifactory-creds',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                )]) {

                    bat '''
                    echo Downloading latest artifact from Artifactory...
                    curl -L -u %USER%:%PASS% -o %ZIP_NAME% %ARTIFACTORY_URL%/eshop-latest.zip
                    '''
                }
            }
        }

        stage('Detect Active Environment') {

            steps {

                script {

                    def proxyContent = readFile(env.PROXY_CONFIG)

                    if(proxyContent.contains("8081")) {

                        env.ACTIVE_ENV  = "blue"
                        env.TARGET_ENV  = "green"
                        env.TARGET_PORT = "8082"
                        env.TARGET_PATH = "C:\\inetpub\\eshop-green"

                    } else {

                        env.ACTIVE_ENV  = "green"
                        env.TARGET_ENV  = "blue"
                        env.TARGET_PORT = "8081"
                        env.TARGET_PATH = "C:\\inetpub\\eshop-blue"

                    }

                    echo "Active Environment : ${env.ACTIVE_ENV}"
                    echo "Deploying To       : ${env.TARGET_ENV}"
                    echo "Deploy Path        : ${env.TARGET_PATH}"
                    echo "Target Port        : ${env.TARGET_PORT}"

                }

            }

        }

        stage('Extract Artifact') {

            steps {

                bat '''
                if exist extracted rmdir /s /q extracted
                powershell Expand-Archive %ZIP_NAME% extracted -Force
                '''

            }

        }

        stage('Deploy to Target Environment') {

            steps {

                bat """
                echo Deploying to ${env.TARGET_ENV}

                robocopy extracted ${env.TARGET_PATH} /E /PURGE /R:1 /W:1 ^
                /XF web.config appsettings.json env.txt

                IF %ERRORLEVEL% LEQ 3 EXIT 0
                """

            }

        }

        stage('Wait For Application Startup') {

            steps {

                echo "Waiting 20 seconds for application startup..."
                sleep(time:20, unit:"SECONDS")

            }

        }

        stage('Health Check') {

            steps {

                script {

                    def retries = 5
                    def success = false

                    for(int i=0; i<retries; i++) {

                        echo "Health check attempt ${i+1}"

                        def status = bat(
                                script: "@curl -s -o nul -w \"%%{http_code}\" http://127.0.0.1:${env.TARGET_PORT}",
                                returnStdout: true
                        ).trim()

                        echo "HTTP Status: ${status}"

                        if(status.contains("200")) {
                            success = true
                            break
                        }

                        sleep(time:5, unit:"SECONDS")

                    }

                    if(!success) {
                        error "Health check failed"
                    }

                }

            }

        }

        stage('Traffic Switch Approval') {

            steps {

                timeout(time: 60, unit: 'MINUTES') {

                    input message: """
TRAFFIC SWITCH APPROVAL REQUIRED

Application : eShop
Current Env : ${env.ACTIVE_ENV}
Target Env  : ${env.TARGET_ENV}

Approve production traffic switch?
"""

                }

            }

        }

        stage('Switch Traffic') {

            steps {

                script {

                    if(env.TARGET_PORT == "8082") {

                        powershell """
                        (Get-Content ${env.PROXY_CONFIG}) -replace '8081','8082' |
                        Set-Content ${env.PROXY_CONFIG}
                        """

                    } else {

                        powershell """
                        (Get-Content ${env.PROXY_CONFIG}) -replace '8082','8081' |
                        Set-Content ${env.PROXY_CONFIG}
                        """

                    }

                    echo "Traffic switched to ${env.TARGET_ENV}"

                }

            }

        }

    }

    post {

        success {

            withCredentials([string(credentialsId: 'slack-webhook', variable: 'SLACK_URL')]) {

                bat """
                curl -X POST -H "Content-type: application/json" ^
                --data "{\\"text\\":\\"SUCCESS: eShop deployed to ${env.TARGET_ENV} - Build ${env.BUILD_NUMBER} - ${env.BUILD_URL}\\"}" ^
                %SLACK_URL%
                """

            }

        }

        failure {

            withCredentials([string(credentialsId: 'slack-webhook', variable: 'SLACK_URL')]) {

                bat """
                curl -X POST -H "Content-type: application/json" ^
                --data "{\\"text\\":\\"FAILED: eShop deployment failed - Build ${env.BUILD_NUMBER} - ${env.BUILD_URL}\\"}" ^
                %SLACK_URL%
                """

            }

        }

    }

}
